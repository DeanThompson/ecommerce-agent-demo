# Anthropic API Key (required, or use ANTHROPIC_AUTH_TOKEN)
ANTHROPIC_API_KEY=your-api-key-here

# Alternative API configuration (optional)
# Use these to connect to compatible API endpoints (e.g., GLM, OpenRouter)
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# ANTHROPIC_AUTH_TOKEN=your-auth-token-here
# ANTHROPIC_MODEL=glm-4.7

# Server Configuration
PORT=3001
NODE_ENV=development
WEB_PORT=8081

# Database Path
DATABASE_PATH=./data/ecommerce.duckdb

# Session storage path (JSONL)
SESSIONS_DIR=./data/sessions

# Basic auth for web gateway (required in docker-compose deployment)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-this-password
